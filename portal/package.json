{
  "name": "fig-portal",
  "version": "0.1.0",
  "private": true,
  "description": "FIG Core Design System ポータル (U2) — vanilla JS 静的 SPA。Core DS を rolling 取込し、3区分IA＋使い方で公開する。",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev-serve.mjs",
    "serve:site": "node scripts/serve-site.mjs",
    "test": "node --test tests/*.test.js",
    "test:vrt": "playwright test tests/vrt",
    "test:a11y": "playwright test tests/a11y",
    "validate": "node scripts/build.mjs --validate-only"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "1.55.0",
    "ajv": "^8.17.1"
  },
  "license": "MIT"
}
